{$APP_DOMAIN} {
    encode gzip

    # OAuth2 Proxy endpoints must stay public so login/callback can work.
    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Uri {uri}
        }
    }

    handle {
        # All application requests require a valid GitHub OAuth session.
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            header_up X-Real-IP {remote_host}
            copy_headers X-Auth-Request-User X-Auth-Request-Email X-Auth-Request-Groups

            # Redirect unauthenticated users to oauth2-proxy sign-in.
            @error status 401
            handle_response @error {
                redir * /oauth2/sign_in?rd={scheme}://{host}{uri}
            }
        }

        reverse_proxy frontend:80
    }
}
