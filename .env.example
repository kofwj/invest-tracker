# Invest Tracker VPS / production example
# Copy this file to .env on your VPS and adjust values. Do NOT commit .env.

APP_TIMEZONE=Asia/Shanghai
DB_PATH=/app/data/invest.db

# System Password / PIN gate protection (Option 2)
# Set a password to enable the lock screen and API authentication.
# Leave empty or comment out to run in public/unlocked mode.
INVEST_TRACKER_PASSWORD=


# Bind frontend to localhost when using Caddy/Nginx reverse proxy.
# Change to 0.0.0.0 only if you intentionally expose it directly.
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8080

# Public domain for Caddy HTTPS and GitHub OAuth callback.
APP_DOMAIN=invest.example.com

# GitHub OAuth App credentials.
# GitHub OAuth callback URL must be: https://invest.example.com/oauth2/callback
GITHUB_OAUTH_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Only this GitHub username can access the app.
GITHUB_OAUTH_ALLOWED_USER=your-github-username

# MUST decode to 16/24/32 bytes (AES). Prefer:
# python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
# Do not wrap in quotes; no trailing spaces. Wrong length => oauth2-proxy Restarting.
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64-secret

# --- 市场摘要 / 价格预警（可选）---
# 进程内行情缓存秒数（默认 120）；0 关闭缓存
# MARKET_QUOTE_CACHE_SECONDS=120
# 飞书机器人 webhook；cron 带 --notify-alerts 且触发时推送
# FEISHU_ALERT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
# CRON_CHECK_ALERTS=1
# CRON_NOTIFY_ALERTS=0
# 同规则预警冷却分钟（默认 240；也可用 settings.alert_cooldown_minutes）
# ALERT_COOLDOWN_MINUTES=240
# 强制写快照（忽略交易日历）
# CRON_FORCE_SNAPSHOT=0

# --- Cloudflare Tunnel（家用 VPS / 无公网 80/443 直连）---
# 隧道 Public Hostname 回源到 http://127.0.0.1:80（Caddy），禁止指 :8080
# CADDYFILE=./caddy/Caddyfile.tunnel
# FRONTEND_BIND=127.0.0.1

