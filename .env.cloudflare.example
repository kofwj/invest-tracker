# Invest Tracker for an existing Cloudflare Tunnel deployment
# Copy to .env.cloudflare on the internal server. Do NOT commit real .env.cloudflare.

APP_TIMEZONE=Asia/Shanghai
DB_PATH=/app/data/invest.db

# Frontend only binds to localhost by default.
# If your existing cloudflared runs on the same host, point it to http://127.0.0.1:8080.
# If cloudflared runs on another LAN host, change FRONTEND_BIND to the LAN IP or 0.0.0.0
# and point Cloudflare Tunnel to http://<this-server-lan-ip>:8080.
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8080

# Local backup retention. Used by scripts/cleanup_backups.sh.
BACKUP_RETENTION_DAYS=60
