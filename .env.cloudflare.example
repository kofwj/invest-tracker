# Invest Tracker Cloudflare Tunnel deployment example
# Copy to .env.cloudflare on the internal server. Do NOT commit real .env.cloudflare.

APP_TIMEZONE=Asia/Shanghai
DB_PATH=/app/data/invest.db

# Frontend only binds to localhost. Cloudflared on the same host connects to it.
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8080

# Create a tunnel in Cloudflare Zero Trust and paste the token here.
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# Local backup retention. Used by scripts/cleanup_backups.sh.
BACKUP_RETENTION_DAYS=60
